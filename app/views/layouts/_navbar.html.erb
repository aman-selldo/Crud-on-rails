<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Dancing+Script&family=Poppins:wght@500&family=Roboto:wght@500&display=swap" rel="stylesheet">
<!-- component -->
<div class="place-items-center">
  <section class="relative mx-auto">
    <!-- navbar -->
    <nav class="flex items-center justify-between text-white" style="background-color: #282828; box-shadow: rgba(100, 100, 111, 0.2) 0px 7px 29px 0px;">
      <div class="flex items-center justify-between w-full px-5 py-6 xl:px-12">
        <!-- Brand -->
        <a class="text-3xl font-bold font-heading nav-title" href="/" style="text-decoration: none;">
          Clipsink
        </a>
        <!-- Nav Links -->
        <ul class="flex space-x-8 font-heading">
          <li class="vertical-align">
            <a href="/" class="">Home</a>
          </li>
          <% if current_user %>
            <li>
              <a href="#" class="hover:text-gray-200 transition duration-300" style="text-decoration: none;">
                <%#= link_to "My Media", pages_media_path %>
              </a>
            </li>
            <li>
              <%= button_to "Log Out", destroy_user_session_path, method: :delete, class: "hover:bg-red-500 transition duration-300 px-3 py-2 bg-red-600 text-white rounded-md", style: "text-decoration: none;" %>
            </li>
          <% else %>
            <li>
              <a href="<%= new_user_registration_path %>" class="hover:text-gray-200 transition duration-300" style="text-decoration: none;">Sign up</a>
            </li>
            <li>
              <a href="<%= new_user_session_path %>" class="bg-white hover:bg-gray-100 text-gray-800 py-2 px-4 border border-gray-400 rounded shadow transition duration-300" style="text-decoration: none;">Login</a>
            </li>
          <% end %>
        </ul>
      </div>
    </nav>
  </section>
</div>
