<%= form_with(model: post) do |form| %>

  <% if post.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 p-4 rounded mb-4">
      <h2 class="font-semibold"><%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:</h2>

      <ul class="list-disc pl-6">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

    <div class="form-wrapper">

      <div class="mb-6">
        <%= form.label :title, style: "display: block", class: "block text-sm font-medium text-gray-700 ml-20" %>
        <%= form.text_field :title, class: "input-field" %>
      </div>

      <div class="mb-6">
        <%= form.label :description, style: "display: block", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :description, class: "input-field" %>
      </div>

      <div>
        <%= form.submit "Submit", class: "btn" %>
      </div>
    </div>
<% end %>
