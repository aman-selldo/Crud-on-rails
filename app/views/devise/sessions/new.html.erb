<div class="grid items-center justify-center">
  <div class="h-full w-full xl:px-32 px-4 mt-12 flex justify-center items-center">
    <div class="w-full max-w-md">
      <h2 class="text-center text-5xl leading-relaxed text-gray-800 font-bold">Welcome Back.</h2>
      
      <!-- Sign Up and Forgot Password Links -->
      <div class="text-center mt-4">
        <%= link_to "Sign Up", new_registration_path(resource_name), class: "text-blue-500 hover:underline text-sm" %> | 
        <%= link_to "Forgot Password?", new_password_path(resource_name), class: "text-blue-500 hover:underline text-sm" %>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: 'bg-white rounded pt-6 pb-8 mb-4' }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%
          label_classes = "block text-md mb-2 mt-4 #{alert ? 'text-red-500' : 'text-gray-700'}"
          input_classes = "shadow appearance-none border rounded w-full py-4 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline #{alert ? 'border-red-500' : nil}"
        %>

        <div class="mb-4">
          <%= f.label :email, "Email", class: label_classes %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: input_classes, required: true %>
        </div>
        <div class="mb-4">
          <%= f.label :password, "Password", class: label_classes %>
          <%= f.password_field :password, autocomplete: "new-password", class: input_classes, required: true %>
        </div>
        <p class="text-center text-md mt-4"> By continuing you agree to our </p>

        <%= f.submit "Login", class: "w-full bg-blue-500 hover:bg-blue-700 text-white mt-2 py-4 px-4 mr-6 rounded focus:outline-none focus:shadow-outline" %>
      <% end %>
    </div>
  </div>

  <div class="image-right">
    <%#= image_tag 'login.jpg', alt: 'My Image', class: 'img-thumbnail', id:"fade-in-image" %>

    <style>
      .img-thumbnail {
        position: absolute;
        width: 50%;
        object-fit: contain;
        right: 0;
      }

      @media (max-width: 1250px) {
        .img-thumbnail {
          display: none;
        }
      }
    </style>
  </div>
</div>
