<div class=" h-full w-full xl:px-32 px-4 mt-12 flex justify-center items-center">
  <div class="grid items-center justify-center mt-50">
    <h2 class="text-center text-3xl leading-relaxed text-gray-800 font-bold ">Sign up</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <!-- Email Field -->
      <div class="field mt-20">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1 mt-6" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-3/4 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-xs sm:text-sm" %>
      </div>

      <!-- Password Field -->
      <div class="field ml-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1 mt-5" %>
        <% if @minimum_password_length %>
          <em class="text-xs text-gray-500">(<%= @minimum_password_length %> characters minimum)</em>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 block w-3/4 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-xs sm:text-sm" %>
      </div>

      <!-- Password Confirmation Field -->
      <div class="field ml-4">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-3/4 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-xs sm:text-sm" %>
      </div>

      <!-- Submit Button -->
      <div class="actions ml-4">
        <%= f.submit "Sign up", class: "w-full bg-blue-500 hover:bg-blue-700 text-white font-bold mt-2 py-4 px-4 mr-6 rounded focus:outline-none focus:shadow-outline" %>
      </div>
    <% end %>
  </div>
</div>
